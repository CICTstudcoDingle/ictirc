# --- Supabase Auth (Core) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Database (Prisma) ---
# Use the connection pooler for the primary URL
DATABASE_URL="postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use the direct connection for migrations
DIRECT_URL="postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres"

# --- Storage Buckets ---
NEXT_PUBLIC_SUPABASE_BUCKET_HOT="archive"
NEXT_PUBLIC_SUPABASE_BUCKET_GUIDES="research guides"
NEXT_PUBLIC_SUPABASE_BUCKET_EVENTS="event-images"

# --- Cloudflare R2 (Cold Storage & Backups) ---
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME_COLD=ictirc-cold

# --- Site URLs & Cross-Linking ---
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_IRJICT_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_ADMIN_URL=http://localhost:3003

# --- Search (Optional) ---
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_PREFIX=ictirc

# --- Other ---
GEMINI_API_KEY=
