generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [fuzzystrmatch]
}

// ============================================
// ENUMS
// ============================================

enum PaperStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  PUBLISHED
  ARCHIVED
  REJECTED
}

enum PlagiarismStatus {
  PENDING    // Not yet checked
  PASS       // Under 15% similarity
  FLAGGED    // 15-25%, needs editor review
  REJECTED   // Over 25%, auto-rejected (Dean can override)
  OVERRIDDEN // Dean overrode a rejection
}

enum UserRole {
  AUTHOR
  REVIEWER
  EDITOR
  DEAN
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum ReleaseType {
  MAJOR
  MINOR
  PATCH
  BETA
  ALPHA
}

enum ChangeType {
  FEATURE
  ENHANCEMENT
  BUGFIX
  SECURITY
  BREAKING
  DEPRECATED
}

enum VideoType {
  PROMOTIONAL // For the department (CICT)
  TEASER      // For the event (IT Week)
}

// ============================================
// DYNAMIC ROLES (Managed by DEAN)
// ============================================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // e.g., "AUTHOR", "REVIEWER", "EDITOR", "DEAN"
  displayName String   // e.g., "Author", "Reviewer", "Editor", "Dean"
  description String?  @db.Text
  permissions String[] @default([]) // Array of permission strings
  isSystem    Boolean  @default(false) // System roles can't be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

// ============================================
// MODELS
// ============================================

model Paper {
  id          String      @id @default(cuid())
  title       String
  abstract    String      @db.Text
  keywords    String[]
  doi         String?     @unique
  status      PaperStatus @default(SUBMITTED)
  pdfUrl      String?
  rawFileUrl  String?
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Archive-specific fields (optional for current papers)
  pageStart     Int?      // Starting page in issue (for archived papers)
  pageEnd       Int?      // Ending page in issue (for archived papers)
  submittedDate DateTime? // Original submission date (for archived papers)
  acceptedDate  DateTime? // Original acceptance date (for archived papers)
  uploadedAt    DateTime? // When archived paper was uploaded
  uploadedBy    String?   // Who uploaded the archived paper

  // Archive issue relation (optional)
  issueId String?
  issue   Issue?  @relation(fields: [issueId], references: [id])

  // R2 Cold Storage Backup
  r2BackupUrl String?   // R2 cold storage URL
  r2BackupAt  DateTime? // Last backup timestamp

  // Plagiarism Check (Manual Recording)
  plagiarismScore    Float?            // Similarity percentage (0-100)
  plagiarismStatus   PlagiarismStatus  @default(PENDING)
  plagiarismCheckedAt DateTime?        // When the check was recorded
  plagiarismCheckedBy String?          // User ID who recorded the result
  plagiarismChecker   User?            @relation("PlagiarismChecker", fields: [plagiarismCheckedBy], references: [id])
  plagiarismNotes    String?           @db.Text // Optional notes (e.g., external tool used, flagged sections)
  plagiarismOverriddenBy String?       // Dean who overrode a rejection
  plagiarismOverrideNote String?       @db.Text // Reason for override

  // Relations
  authors    PaperAuthor[]
  category   Category      @relation(fields: [categoryId], references: [id])
  categoryId String
  comments   PaperComment[]
  reviewers  PaperReviewer[]
  uploader   User?         @relation("UploadedPapers", fields: [uploadedBy], references: [id])

  // Publication Tracking (1-7)
  publicationStep Int     @default(1)
  publicationNote String?

  @@index([status])
  @@index([categoryId])
  @@index([publishedAt])
  @@index([issueId])
  @@index([uploadedAt])
  @@index([plagiarismStatus])
}

model Author {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  affiliation String?
  avatarUrl   String?  // Profile image URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  papers PaperAuthor[]

  @@index([email])
}

model PaperAuthor {
  id                    String  @id @default(cuid())
  order                 Int     @default(0)
  isCorrespondingAuthor Boolean @default(false)
  paper                 Paper   @relation(fields: [paperId], references: [id], onDelete: Cascade)
  paperId               String
  author                Author  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId              String

  @@unique([paperId, authorId])
  @@index([paperId])
  @@index([authorId])
  @@index([isCorrespondingAuthor])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Hierarchy Connection
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")

  // Relations
  papers         Paper[]
  archivedPapers ArchivedPaper[]

  @@index([parentId])
}

model PaperComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  paper    Paper   @relation(fields: [paperId], references: [id], onDelete: Cascade)
  paperId  String
  author   User    @relation(fields: [authorId], references: [id])
  authorId String

  @@index([paperId])
  @@index([authorId])
  @@index([createdAt])
}

model PaperReviewer {
  id         String    @id @default(cuid())
  assignedAt DateTime  @default(now())
  reviewedAt DateTime?

  // Relations
  paper      Paper   @relation(fields: [paperId], references: [id], onDelete: Cascade)
  paperId    String
  reviewer   User    @relation(fields: [reviewerId], references: [id])
  reviewerId String

  @@unique([paperId, reviewerId])
  @@index([paperId])
  @@index([reviewerId])
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id        String   @id // Supabase Auth UID
  email     String   @unique
  name      String?
  role      UserRole @default(AUTHOR)
  isActive  Boolean  @default(true)
  avatarUrl String?  // Profile image URL
  position  String?  // Faculty/Staff position
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  invites          InviteToken[]
  comments         PaperComment[]
  assignedPapers   PaperReviewer[]
  uploadedArchives ArchivedPaper[]
  uploadedPapers   Paper[]         @relation("UploadedPapers")
  plagiarismChecks Paper[]         @relation("PlagiarismChecker")
  releases         Release[]

  @@index([email])
  @@index([role])
}

model InviteToken {
  id        String       @id @default(cuid())
  email     String
  role      UserRole     @default(AUTHOR)
  token     String       @unique @default(cuid())
  status    InviteStatus @default(PENDING)
  expiresAt DateTime
  createdAt DateTime     @default(now())

  // Relations
  invitedBy   User?   @relation(fields: [invitedById], references: [id])
  invitedById String?

  @@index([token])
  @@index([email])
  @@index([status])
}

// ============================================
// EVENTS & RESEARCH GUIDES
// ============================================

model ResearchGuide {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   // Legacy field, migrate to guideCategory
  fileUrl     String
  order       Int      @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // New Relation
  guideCategoryId String?
  guideCategory   ResearchGuideCategory? @relation(fields: [guideCategoryId], references: [id])

  @@index([category])
  @@index([isPublished])
  @@index([guideCategoryId])
}

model ResearchGuideCategory {
  id          String          @id @default(cuid())
  name        String          @unique
  slug        String          @unique
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  guides      ResearchGuide[]

  @@index([slug])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@index([key])
}

// ============================================
// AUDIT & TRACKING
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String?
  action     String
  targetId   String
  targetType String
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetId])
  @@index([createdAt])
}

model DoiSequence {
  id    String @id @default("doi_counter")
  year  Int
  count Int    @default(0)

  @@unique([year])
}

// ============================================
// ARCHIVE MODELS
// ============================================

model Volume {
  id           String   @id @default(cuid())
  volumeNumber Int
  year         Int
  description  String?  @db.Text
  coverImageUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  issues Issue[]

  @@unique([volumeNumber, year])
  @@index([year])
  @@index([volumeNumber])
}

model Issue {
  id            String   @id @default(cuid())
  issueNumber   Int
  month         String?
  publishedDate DateTime
  issn          String?
  theme         String?  @db.Text
  description   String?  @db.Text
  coverImageUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  volume         Volume          @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  volumeId       String
  conference     Conference?     @relation(fields: [conferenceId], references: [id])
  conferenceId   String?
  archivedPapers ArchivedPaper[] // Keep existing archived papers
  papers         Paper[]         // Add unified papers relation

  @@unique([volumeId, issueNumber])
  @@index([volumeId])
  @@index([conferenceId])
  @@index([publishedDate])
}

model Conference {
  id          String    @id @default(cuid())
  name        String
  fullName    String?   @db.Text
  description String?   @db.Text
  startDate   DateTime
  endDate     DateTime?
  location    String?
  venue       String?   @db.Text
  theme       String?   @db.Text
  organizers  String[]  @default([])
  partners    String[]  @default([])
  logoUrl     String?
  imageUrl    String?
  websiteUrl  String?
  isPublished Boolean   @default(true)
  isActive    Boolean   @default(false) // Only one active for landing page
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  issues    Issue[]
  committee CommitteeMember[]
  speakers  KeynoteSpeaker[]

  @@index([startDate])
  @@index([isPublished])
  @@index([isActive])
}

model CommitteeMember {
  id           String     @id @default(cuid())
  conferenceId String
  conference   Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)

  name         String     // e.g., "DR. RENANTE A. DIAMANTE"
  position     String     // e.g., "Overall Chair", "IT Chair"
  affiliation  String?    // Institution name
  email        String?
  photoUrl     String?
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([conferenceId])
  @@index([displayOrder])
}

model KeynoteSpeaker {
  id           String     @id @default(cuid())
  conferenceId String
  conference   Conference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)

  name         String     // e.g., "Dr. Indriati, S.T., M.Kom."
  title        String?    // Academic title/honorific
  position     String     // e.g., "Lecturer – Faculty of Computer Science"
  affiliation  String?    // e.g., "Universitas Brawijaya"
  location     String?    // e.g., "Malang, Indonesia"
  bio          String?    @db.Text
  photoUrl     String?    // Uploaded via drag-and-drop to Supabase Storage
  displayOrder Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([conferenceId])
  @@index([displayOrder])
}

model ArchivedPaper {
  id            String    @id @default(cuid())
  title         String
  abstract      String    @db.Text
  keywords      String[]
  doi           String?   @unique
  pdfUrl        String
  docxUrl       String?
  pageStart     Int?
  pageEnd       Int?
  publishedDate DateTime
  submittedDate DateTime?
  acceptedDate  DateTime?
  uploadedAt    DateTime  @default(now())
  uploadedBy    String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  authors    ArchivedPaperAuthor[]
  category   Category              @relation(fields: [categoryId], references: [id])
  categoryId String
  issue      Issue                 @relation(fields: [issueId], references: [id], onDelete: Cascade)
  issueId    String
  uploader   User                  @relation(fields: [uploadedBy], references: [id])

  @@index([issueId])
  @@index([categoryId])
  @@index([publishedDate])
  @@index([uploadedAt])
}

model ArchivedPaperAuthor {
  id              String  @id @default(cuid())
  name            String
  email           String?
  affiliation     String?
  order           Int     @default(0)
  isCorresponding Boolean @default(false)

  // Relations
  paper   ArchivedPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  paperId String

  @@index([paperId])
  @@index([email])
}

// ============================================
// VERSION & CHANGELOG MODELS
// ============================================

model Release {
  id              String      @id @default(cuid())
  version         String      @unique // e.g., "1.1.0"
  versionType     ReleaseType
  releaseDate     DateTime
  gitCommitHash   String?
  gitTag          String?
  githubReleaseId String?     @unique
  title           String
  description     String?     @db.Text
  isPublished     Boolean     @default(false)
  isBeta          Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  createdBy       String
  
  // Relations
  creator User            @relation(fields: [createdBy], references: [id])
  entries ChangelogEntry[]
  
  @@index([releaseDate])
  @@index([isPublished])
  @@index([version])
}

model ChangelogEntry {
  id          String     @id @default(cuid())
  title       String
  description String     @db.Text
  changeType  ChangeType
  prNumber    Int? // GitHub PR number
  prUrl       String?
  issueNumber Int? // GitHub issue number
  issueUrl    String?
  order       Int        @default(0) // For custom ordering
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  // Relations
  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  releaseId String
  
  @@index([releaseId])
  @@index([changeType])
  @@index([order])
}

// ============================================
// HOME PAGE CONTENT (Admin-Editable)
// ============================================

model HomeContent {
  id                String   @id @default(cuid())
  section           String   @unique // e.g., "hero", "sponsors", "cta"
  title             String?
  subtitle          String?  @db.Text
  content           Json?    // Flexible JSON for section-specific data
  imageUrl          String?
  isPublished       Boolean  @default(true)
  displayOrder      Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([section])
  @@index([isPublished])
  @@map("home_content")
}

// ============================================
// FEEDBACK SYSTEM
// ============================================

model Feedback {
  id          String   @id @default(cuid())
  name        String?  // Optional – anonymous allowed
  email       String?  // Optional – anonymous allowed
  subject     String?
  category    String   @default("General") // "General", "Bug Report", "Feature Request", "Content", "Other"
  message     String   @db.Text
  rating      Int?     // Optional 1-5 star rating
  userAgent   String?  // Browser info for debugging
  isRead      Boolean  @default(false)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([isRead])
  @@index([category])
  @@map("feedback")
}

// ============================================
// PROMOTIONAL VIDEOS
// ============================================

model PromotionalVideo {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  type        VideoType // PROMOTIONAL (CICT) or TEASER (IT Week)
  r2Key       String    // R2 object key for the video file
  thumbnailUrl String?  // Optional thumbnail image URL
  editorName  String    // Name of the editor/uploader
  isPublished Boolean   @default(true)
  uploadDate  DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([isPublished])
  @@index([uploadDate])
}

// ============================================
// PORTAL ENUMS
// ============================================

enum PortalUserType {
  STUDENT
  FACULTY
  ALUMNI
}

enum PortalRole {
  STUDENT        // Regular student
  SC_OFFICER     // Student Council Officer
  SC_SECRETARY   // Secretary role
  SC_TREASURER   // Treasurer role
  SC_PRESIDENT   // SC President
  SC_ADVISER     // Faculty adviser
  PORTAL_ADMIN   // Portal administrator
}

enum PortalAnnouncementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PortalEventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

// ============================================
// PORTAL MODELS (CICT Tech Portal)
// ============================================

model PortalProfile {
  id              String          @id // Supabase Auth UID — same as User.id if user exists there too
  email           String          @unique
  name            String?
  universityId    String?         @unique // e.g., "2021-12345"
  userType        PortalUserType  @default(STUDENT)
  portalRole      PortalRole      @default(STUDENT)
  course          String?         // e.g., "BSIT", "BSCS"
  yearLevel       Int?            // 1-4 for students
  section         String?         // e.g., "A", "B"
  graduationYear  Int?            // For auto-alumni detection
  contactNo       String?
  address         String?
  avatarUrl       String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  eventRegistrations PortalEventRegistration[]
  feedback           PortalFeedback[]

  @@index([email])
  @@index([userType])
  @@index([portalRole])
  @@index([graduationYear])
  @@index([universityId])
  @@map("portal_profiles")
}

model PortalAnnouncement {
  id          String                    @id @default(cuid())
  title       String
  slug        String                    @unique
  content     String                    @db.Text
  excerpt     String?                   @db.Text
  coverImage  String?
  status      PortalAnnouncementStatus  @default(DRAFT)
  isPinned    Boolean                   @default(false)
  publishedAt DateTime?
  authorId    String?                   // Portal admin who published
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([status])
  @@index([publishedAt])
  @@index([slug])
  @@map("portal_announcements")
}

model PortalEvent {
  id            String            @id @default(cuid())
  title         String
  slug          String            @unique
  description   String            @db.Text
  location      String?
  venue         String?
  coverImage    String?
  status        PortalEventStatus @default(UPCOMING)
  eventDate     DateTime
  eventEndDate  DateTime?
  maxAttendees  Int?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Relations
  registrations PortalEventRegistration[]

  @@index([status])
  @@index([eventDate])
  @@index([slug])
  @@map("portal_events")
}

model PortalEventRegistration {
  id          String   @id @default(cuid())
  status      String   @default("registered") // registered, cancelled, attended
  registeredAt DateTime @default(now())

  // Relations
  event    PortalEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId  String
  user     PortalProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
  @@map("portal_event_registrations")
}

model PortalFeedback {
  id         String   @id @default(cuid())
  subject    String?
  category   String   @default("General") // General, Bug Report, Feature Request, etc.
  message    String   @db.Text
  rating     Int?     // 1-5 stars
  isRead     Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())

  // Relations
  author   PortalProfile? @relation(fields: [authorId], references: [id])
  authorId String?

  @@index([createdAt])
  @@index([isRead])
  @@index([category])
  @@map("portal_feedback")
}

model PortalAcademicYear {
  id          String   @id @default(cuid())
  yearStart   Int      // e.g., 2025
  yearEnd     Int      // e.g., 2026
  theme       String?
  isCurrent   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  officers PortalOfficer[]

  @@unique([yearStart, yearEnd])
  @@index([isCurrent])
  @@map("portal_academic_years")
}

model PortalOfficer {
  id              String   @id @default(cuid())
  name            String
  position        String   // e.g., "President", "Vice President"
  photoUrl        String?
  displayOrder    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  academicYear   PortalAcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  academicYearId String

  @@index([academicYearId])
  @@index([displayOrder])
  @@map("portal_officers")
}

model MemberCountSnapshot {
  id         String   @id @default(cuid())
  students   Int      @default(0)
  faculty    Int      @default(0)
  alumni     Int      @default(0)
  recordedAt DateTime @default(now())

  @@index([recordedAt])
  @@map("member_count_snapshots")
}

// ============================================
// CICT ADMIN: ENROLLMENT + CASHIER
// ============================================

enum CictAdminRole {
  ADMIN
  FACULTY
  OFFICER
}

enum CictEnrollmentStatus {
  SUBMITTED
  APPROVED
  REJECTED
  PAID
  ENROLLED
}

enum CictStudentType {
  INCOMING
  REGULAR
}

enum CictCashierPaymentStatus {
  POSTED
  VOID
}

enum CictCashierPaymentMethod {
  CASH
}

model CictAdminProfile {
  id        String        @id // Supabase Auth UID
  email     String        @unique
  name      String?
  role      CictAdminRole @default(OFFICER)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  cashierPayments CictCashierPayment[]       @relation("CashierPayments")
  issuedReceipts  CictReceipt[]              @relation("IssuedReceipts")
  statusChanges   CictEnrollmentStatusHistory[]
  auditEvents     CictAuditEvent[]           @relation("CictAuditActor")

  @@index([email])
  @@index([role])
  @@map("cict_admin_profiles")
}

model CictDepartment {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feeSchedules CictDepartmentFee[]
  enrollments  CictEnrollment[]

  @@index([isActive])
  @@map("cict_departments")
}

model CictDepartmentFee {
  id           String   @id @default(cuid())
  academicYear String
  amount       Decimal  @default(50) @db.Decimal(10, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   CictDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  departmentId String

  @@unique([departmentId, academicYear])
  @@index([academicYear])
  @@map("cict_department_fees")
}

model CictEnrollment {
  id            String               @id @default(cuid())
  studentType   CictStudentType      @default(INCOMING)
  studentName   String
  studentNumber String
  program       String
  yearLevel     Int
  sectionName   String?
  departmentFee Decimal              @default(50) @db.Decimal(10, 2)
  paidAmount    Decimal              @default(0) @db.Decimal(10, 2)
  status        CictEnrollmentStatus @default(SUBMITTED)
  remarks       String?              @db.Text
  submittedAt   DateTime             @default(now())
  approvedAt    DateTime?
  paidAt        DateTime?
  sectionAssignedAt DateTime?
  enrolledAt    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  department         CictDepartment               @relation(fields: [departmentId], references: [id])
  departmentId       String
  payments           CictCashierPayment[]
  statusHistory      CictEnrollmentStatusHistory[]

  @@index([studentNumber])
  @@index([studentType])
  @@index([status])
  @@index([departmentId])
  @@map("cict_enrollments")
}

model CictEnrollmentStatusHistory {
  id         String               @id @default(cuid())
  fromStatus CictEnrollmentStatus?
  toStatus   CictEnrollmentStatus
  note       String?              @db.Text
  createdAt  DateTime             @default(now())

  enrollment   CictEnrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  enrollmentId String
  actor        CictAdminProfile @relation(fields: [actorId], references: [id])
  actorId      String

  @@index([enrollmentId])
  @@index([actorId])
  @@index([createdAt])
  @@map("cict_enrollment_status_history")
}

model CictCashierPayment {
  id              String                   @id @default(cuid())
  amount          Decimal                  @db.Decimal(10, 2)
  method          CictCashierPaymentMethod @default(CASH)
  status          CictCashierPaymentStatus @default(POSTED)
  referenceNumber String
  postedAt        DateTime                 @default(now())
  createdAt       DateTime                 @default(now())

  enrollment   CictEnrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  enrollmentId String
  cashier      CictAdminProfile @relation("CashierPayments", fields: [cashierId], references: [id])
  cashierId    String
  receipt      CictReceipt?

  @@index([enrollmentId])
  @@index([cashierId])
  @@index([postedAt])
  @@map("cict_cashier_payments")
}

model CictReceipt {
  id         String   @id @default(cuid())
  receiptNo  String   @unique
  payerName  String
  issuedAt   DateTime @default(now())
  remarks    String?  @db.Text
  createdAt  DateTime @default(now())

  payment   CictCashierPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  paymentId String             @unique
  issuedBy  CictAdminProfile   @relation("IssuedReceipts", fields: [issuedById], references: [id])
  issuedById String

  @@index([issuedAt])
  @@index([issuedById])
  @@map("cict_receipts")
}

model CictAuditEvent {
  id         String   @id @default(cuid())
  action     String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor    CictAdminProfile @relation("CictAuditActor", fields: [actorId], references: [id])
  actorId  String

  @@index([actorId])
  @@index([targetType])
  @@index([targetId])
  @@index([createdAt])
  @@map("cict_audit_events")
}
